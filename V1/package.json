{
  "name": "avatar-project",
  "version": "0.1.0",
  "description": "Avatar Project - 你的数字工作伙伴",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:ui": "vite",
    "build:ui": "tsc && vite build",
    "lint": "eslint src --ext .ts,.tsx 2>/dev/null || echo 'ESLint not configured'",
    "format": "prettier --write src 2>/dev/null || echo 'Prettier not configured'"
  },
  "keywords": ["avatar", "ai", "automation", "productivity"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.3.3",
    "electron-store": "^8.1.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/crypto-js": "^4.2.2",
    "@types/uuid": "^9.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "vite-tsconfig-paths": "^4.3.2",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.18"
  },
  "build": {
    "appId": "com.avatar-project.app",
    "productName": "Avatar Project",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
